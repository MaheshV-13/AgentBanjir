# ─── AgentBanjir Backend — Environment Variables ──────────────────────────────
#
# COPY THIS FILE: cp .env.example .env
# POPULATE VALUES in .env before running the server.
# .env is in .gitignore and must NEVER be committed to version control.
#
# In production (Cloud Run), these values are injected from GCP Secret Manager
# via the --set-secrets flag in deploy.sh. Do NOT set them as Dockerfile ENV
# instructions or docker build --build-arg values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Google Cloud ───────────────────────────────────────────────────────────────
# GCP project ID. Used by Vertex AI and Secret Manager SDK clients.
GOOGLE_CLOUD_PROJECT=agentbanjir-hackathon-prod

# Gemini API key. Obtain from https://aistudio.google.com/app/apikey
# In production, injected from Secret Manager secret: gemini-api-key
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── Server ─────────────────────────────────────────────────────────────────────
# Port the Express server binds to.
# Cloud Run injects PORT=8080 automatically — do not override in production.
PORT=8080

# Execution environment. Controls log format (JSON vs colourised) and error verbosity.
# Allowed values: development | production | test
NODE_ENV=development

# ── CORS ───────────────────────────────────────────────────────────────────────
# Member 3's Vite dashboard origin. Whitelisted in corsConfig.ts.
# Development default: http://localhost:5173
# Production: replace with Cloud Run URL or static host URL.
VITE_FRONTEND_ORIGIN=http://localhost:5173

# ── Logging ────────────────────────────────────────────────────────────────────
# Winston log level. Allowed values: error | warn | info | debug
# Set to "debug" to enable full request/response detail (DEBUG_MODE equivalent).
LOG_LEVEL=info

# Set to "true" to enable file transport (logs/app.log).
# Disabled by default; useful for local debugging without Cloud Logging.
LOG_TO_FILE=false
