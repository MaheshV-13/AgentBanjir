{
  "name": "agentbanjir-backend",
  "version": "1.0.0",
  "description": "AgentBanjir — AI-Powered Flood Crisis Response API Gateway",
  "author": "AgentBanjir Team, GDG On Campus UTM",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json && tsc-alias",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:ci": "jest --runInBand --forceExit --ci --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@genkit-ai/core": "^1.30.1",
    "@genkit-ai/googleai": "^1.28.0",
    "@genkit-ai/vertexai": "^1.30.1",
    "@google-cloud/discoveryengine": "^2.5.3",
    "@google-cloud/vertexai": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "genkit": "^1.30.1",
    "helmet": "^7.1.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.9",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.16.2",
    "typescript": "^5.9.3"
  }
}
